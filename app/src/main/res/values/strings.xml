    <!-- region Commitment Password Feature -->
    <string name="feature.commitmentPassword">Commitment Password</string>
    <string name="feature.commitmentPassword.subtitle">Lock settings with a passphrase</string>
    <string name="feature.commitmentPassword.description">Protect selected DetoxDroid settings with a passphrase so they cannot be changed impulsively. Requires Device Admin.</string>
    <string name="feature.commitmentPassword.requiresDeviceAdmin">Device Admin required</string>
    <string name="feature.commitmentPassword.requiresDeviceAdmin.message">Grant Device Admin to enable Commitment Password.</string>
    <string name="feature.commitmentPassword.walkthrough.title">Before You Enable This</string>
    <string name="feature.commitmentPassword.walkthrough.message">Enabling Commitment Password will:\n\n• Lock selected settings\n• Require your passphrase for changes\n• Prevent stopping DetoxDroid while locked\n• Allow 3 attempts, then a 5-minute cooldown\n• Offer 24-hour recovery if forgotten\n\nOnly enable this if you stored your passphrase safely.\n\nContinue?</string>
    <string name="feature.commitmentPassword.walkthrough.proceed">I Understand</string>
    <string name="feature.commitmentPassword.generated.title">Your Passphrase</string>
    <string name="feature.commitmentPassword.generated.message">Save this passphrase now. You need it to change protected settings:\n\n%s\n\nWrite it down or store it in a secure place before continuing.</string>
    <string name="feature.commitmentPassword.generated.copied">Passphrase copied to clipboard</string>
    <string name="feature.commitmentPassword.generated.confirm">I Saved the Passphrase</string>
    <string name="feature.commitmentPassword.copy">Copy Passphrase</string>
    <string name="feature.commitmentPassword.unlock">Unlock Settings</string>
    <string name="feature.commitmentPassword.unlock.description">Enter your passphrase to unlock settings for this session.</string>
    <string name="feature.commitmentPassword.enter">Enter Passphrase</string>
    <string name="feature.commitmentPassword.verify">Verify</string>
    <string name="feature.commitmentPassword.incorrect">Wrong passphrase</string>
    <string name="feature.commitmentPassword.attemptsRemaining">%d attempts remaining</string>
    <string name="feature.commitmentPassword.lockedOut">Too many failed attempts. Try again in %s.</string>
    <string name="feature.commitmentPassword.forgot">Forgot Passphrase?</string>
    <string name="feature.commitmentPassword.recovery.title">Passphrase Recovery</string>
    <string name="feature.commitmentPassword.recovery.message">If you forgot your passphrase, start a 24-hour recovery timer. After it ends, you can reset the passphrase.\n\nSettings stay locked during recovery.</string>
    <string name="feature.commitmentPassword.recovery.initiate">Start 24-Hour Recovery</string>
    <string name="feature.commitmentPassword.recovery.inProgress">Recovery in Progress</string>
    <string name="feature.commitmentPassword.recovery.timeRemaining">Time remaining: %s</string>
