    <!-- region Device Admin Revoked Warning -->
    <string name="deviceAdminRevoked.title">Device Admin was deactivated</string>
    <string name="deviceAdminRevoked.message">You locked DetoxDroid with Commitment Password and then removed Device Admin. This may be part of an attempt to uninstall or bypass your commitment. Take a moment to decide intentionally.</string>
    <string name="accessibilityDisabledWarning.title">Accessibility Service was disabled</string>
    <string name="accessibilityDisabledWarning.message">The DetoxDroid Accessibility Service was disabled while Commitment Password is active. DetoxDroid needs this service to enforce your commitment settings. Please re-enable it to continue.</string>
    <string name="deviceAdminRevoked.prompt">To continue, type this sentence exactly:</string>
    <string name="deviceAdminRevoked.requiredPhrase">I am making a short-term decision that I will regret</string>
    <string name="deviceAdminRevoked.inputLabel">Type the sentence</string>
    <string name="deviceAdminRevoked.continue">I understand, continue</string>
    <string name="deviceAdminRevoked.reenable.explanation">DetoxDroid uses Device Admin to make your commitment harder to bypass. Re-enable it to restore full protection.</string>
    <string name="deviceAdminRevoked.disableRequestedWarning">Commitment Password is active. Disabling Device Admin makes DetoxDroid easier to uninstall and bypass your commitment.</string>
