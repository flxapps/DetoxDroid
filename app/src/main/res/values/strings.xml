    <string name="feature.commitmentPassword.generated.confirm">I Saved the Passphrase</string>
    <string name="feature.commitmentPassword.copy">Copy Passphrase</string>
    <string name="feature.commitmentPassword.unlock">Unlock Settings</string>
    <string name="feature.commitmentPassword.unlock.description">Enter your passphrase to unlock settings for this session.</string>
