    <string name="feature.disableApps">Disable Apps</string>
    <string name="feature.disableApps.subtitle">Forget about them</string>
    <string name="feature.disableApps.description">DetoxDroid can either block or even completely deactivate apps while being active. Thereby, they cannot be started from the launcher nor can they send you notifications.</string>
    <string name="feature.disableApps.manage">Manage Deactivated Apps</string>
    <string name="feature.disableApps.manage._defined">%d apps listed for deactivation</string>
    <string name="feature.disableApps.allowedDailyTime">Allowed Daily Screen Time</string>
    <string name="feature.disableApps.allowedDailyTime.description">Select how much screen time you want to allow yourself to use these apps per day. Once the time is up, they will be deactivated until the next day. (DetoxDroid has to be running for screen time tracking.)</string>
    <string name="feature.disableApps.operationMode">Operation Mode</string>
    <string name="feature.disableApps.operationMode.description">Select whether you want to block apps (i.e. show a warn screen when opening them) or completely deactivate them. The latter mode will need specific permissions.</string>
