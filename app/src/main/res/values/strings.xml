    <string name="home.uninstall">Uninstall DetoxDroid</string>
    <string name="home.uninstall.hint">It might not be possible for you to uninstall DetoxDroid normally, as you have granted particular permissions by installing it from your computer. Press here to uninstall.</string>
    <string name="home.uninstall.dialog.title">Are You Sure?</string>
    <string name="home.uninstall.dialog.message">Pressing \"Uninstall\" will revoke permissions that you granted to DetoxDroid. You will then be able to uninstall it normally.\n\nIf you choose to use DetoxDroid again, you will have to grant these permissions again.</string>

    <string name="feature.doNotDisturb">\"Do Not Disturb\" Mode</string>
    <string name="feature.doNotDisturb.subtitle">Make it your new default</string>
    <string name="feature.doNotDisturb.description">DetoxDroid automatically (re-)activates the do not disturb mode. Exceptions can be made with the system settings.</string>
    <string name="feature.doNotDisturb.systemSettings">System Settings</string>
    <string name="feature.doNotDisturb.systemSettings.description">You can make in-depth adjustments to the do not disturb mode in the system settings.</string>

    <string name="feature.grayscale">Automatic Grayscale</string>
    <string name="feature.grayscale.subtitle">Color up by coloring down your phone</string>
    <string name="feature.grayscale.description">Apps compete for your attention, and colors can have an enticing, manipulative effect. With DetoxDroid, you can strip away all the neuron-stimulating colors, while allowing exceptions where necessary.</string>
    <string name="feature.grayscale.allowedColorScreenTime">Allowed Daily Color Screen Time</string>
    <string name="feature.grayscale.allowedColorScreenTime.description">Select how much screen time you want to allow per day until the Automatic Grayscale mode activates. (DetoxDroid has to be running for screen time tracking.)</string>
    <string name="feature.grayscale.extraDim">Extra Dim</string>
    <string name="feature.grayscale.extraDim.description.description">Dim your screen while using grayscale mode. (Long-press to adjust intensity.)</string>
    <string name="feature.grayscale.ignoreNonFullScreen">Ignore Non-Fullscreen Apps</string>
    <string name="feature.grayscale.ignoreNonFullScreen.description">Non-fullscreen components (e.g. sound volume box, status bar) will be ignored, i.e. the color state will not be changed.</string>
    <string name="feature.grayscale.exceptions.states.gray">Gray</string>
    <string name="feature.grayscale.exceptions.states.colors">Colors</string>
    <string name="feature.grayscale.exceptions.states.ignored">Ignored</string>

    <string name="feature.pause">Pause Button</string>
    <string name="feature.pause.subtitle">Take a break from taking a break</string>
    <string name="feature.pause.description">DetoxDroid can be paused for a defined period of time, for example if you want to take a quick look on a photo somebody sent you. A pause can be made by pressing the quick settings tile, by using the assistant or by long-pressing a button on your phone for 2 seconds.</string>
    <string name="feature.pause.duration">Pause Duration</string>
    <string name="feature.pause.duration.description">Once the pause is over, DetoxDroid will automatically come back into life.</string>
    <string name="feature.pause.minimumTimeBetween">Minimum Time Between Pauses</string>
    <string name="feature.pause.minimumTimeBetween.description">Don\'t cheat yourself by habitually pressing the pause button all the time.</string>
    <string name="feature.pause.fromAssistant">Pause from Assistant</string>
    <string name="feature.pause.fromAssistant.description">Set DetoxDroid as your default assistant app to start a pause. (Usually, the assistant can be started by long-pressing the home button.)</string>
    <string name="feature.pause.fromHardwareButton">Pause from Hardware Button</string>
    <string name="feature.pause.fromHardwareButton.description">Select a hardware button that you can long-press for 2 seconds to pause DetoxDroid.</string>
    <string name="feature.pause.fromHardwareButton.press">Press any hardware button on your phone</string>
    <string name="feature.pause.fromHardwareButton.noButtonPressed">No button pressed yet</string>
    <string name="feature.pause.fromHardwareButton.selected">Selected button: %s</string>
    <string name="feature.pause.fromHardwareButton.assign">Assign</string>
    <string name="feature.pause.fromHardwareButton.unset">Delete Assignment</string>
    <string name="feature.pause.fromHardwareButton.appNotRunning">DetoxDroid has to be running in order to assign a new hardware button.</string>
    <string name="feature.pause.notification.settings">Foreground Notification</string>
    <string name="feature.pause.notification.settings.description">Configure notification with pause button. Grant notification permission to enable.</string>

    <string name="feature.doomScrolling">Break "Infinite Scrolling"</string>
    <string name="feature.doomScrolling.subtitle">Don\'t get lost in obsessive checking behaviors</string>
    <string name="feature.doomScrolling.description">EXPERIMENTAL – Infinite scrolling is a manipulative design technology that eliminates those brief moments where you might turn to another activity. DetoxDroid can try to detect if you have been lost in such behavior and offer you an exit.</string>
    <string name="feature.doomScrolling.timeUntilWarning">Time Until Warning</string>
    <string name="feature.doomScrolling.timeUntilWarning.description">DetoxDroid will notify you if it detects that you have been "doom scrolling" for this duration.</string>

